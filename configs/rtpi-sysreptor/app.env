# SysReptor Application Configuration
# IMPORTANT: Change SECRET_KEY and ENCRYPTION_KEYS before production deployment
#
# Generate SECRET_KEY with:
#   python3 -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Or:
#   openssl rand -base64 50
#
# Generate ENCRYPTION_KEY with:
#   python3 -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"

# Security Keys (CHANGE THESE)
SECRET_KEY=change-me-generate-with-django-get_random_secret_key-or-openssl-rand-base64-50

# Database Configuration (points to shared RTPI postgres container)
DATABASE_HOST=postgres
DATABASE_NAME=sysreptor
DATABASE_USER=sysreptor
DATABASE_PASSWORD=sysreptorpassword
DATABASE_PORT=5432

# Encryption Keys (CHANGE THESE — JSON array of AES-GCM keys)
# Generate: python3 -c "import os,base64,uuid; key=base64.b64encode(os.urandom(32)).decode(); id=str(uuid.uuid4()); print(f'[{{\"id\":\"{id}\",\"key\":\"{key}\",\"cipher\":\"AES-GCM\",\"revoked\":false}}]')"
ENCRYPTION_KEYS=[{"id":"00000000-0000-0000-0000-000000000001","key":"CHANGE_ME_base64_encoded_32_byte_aes_key_here_replace_this","cipher":"AES-GCM","revoked":false}]
DEFAULT_ENCRYPTION_KEY_ID=00000000-0000-0000-0000-000000000001

# Security and Access
ALLOWED_HOSTS=sysreptor,sysreptor-app,0.0.0.0,127.0.0.1,localhost
SECURE_SSL_REDIRECT=off
USE_X_FORWARDED_HOST=on
DEBUG=off

# Redis Configuration (dedicated sysreptor-redis container)
REDIS_HOST=sysreptor-redis
REDIS_PORT=6379
REDIS_INDEX=0
REDIS_PASSWORD=sysreptorredispassword

# Task Queue (Celery via Redis)
CELERY_BROKER_URL=redis://:sysreptorredispassword@sysreptor-redis:6379/0
CELERY_RESULT_BACKEND=redis://:sysreptorredispassword@sysreptor-redis:6379/0

# Features and Plugins
ENABLE_PRIVATE_DESIGNS=true
DISABLE_WEBSOCKETS=true
ENABLED_PLUGINS=cyberchef,graphqlvoyager,checkthehash
