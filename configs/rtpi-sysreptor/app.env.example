# SysReptor Application Configuration
# Copy this file to app.env and fill in real values before deployment:
#   cp app.env.example app.env
#
# Generate SECRET_KEY:
#   openssl rand -base64 50
#
# Generate ENCRYPTION_KEYS:
#   python3 -c "import os,base64,uuid; key=base64.b64encode(os.urandom(32)).decode(); id=str(uuid.uuid4()); print(f'[{{\"id\":\"{id}\",\"key\":\"{key}\",\"cipher\":\"AES-GCM\",\"revoked\":false}}]')"

# Security Keys (CHANGE THESE)
SECRET_KEY=change-me-generate-with-openssl-rand-base64-50
ENCRYPTION_KEYS=[{"id":"00000000-0000-0000-0000-000000000001","key":"CHANGE_ME_base64_encoded_32_byte_aes_key","cipher":"AES-GCM","revoked":false}]
DEFAULT_ENCRYPTION_KEY_ID=00000000-0000-0000-0000-000000000001

# Database Configuration (shared RTPI postgres container)
DATABASE_HOST=postgres
DATABASE_NAME=sysreptor
DATABASE_USER=sysreptor
DATABASE_PASSWORD=sysreptorpassword
DATABASE_PORT=5432

# Security and Access
# Add your production domain(s) to ALLOWED_HOSTS
ALLOWED_HOSTS=c3s-reports.attck.nexus,sysreptor,sysreptor-app,0.0.0.0,127.0.0.1,192.168.1.96,attck.nexus,localhost
SECURE_SSL_REDIRECT=on
USE_X_FORWARDED_HOST=on
USE_X_FORWARDED_PORT=on
DEBUG=off

# Redis Configuration (dedicated sysreptor-redis container)
REDIS_HOST=sysreptor-redis
REDIS_PORT=6379
REDIS_INDEX=0
REDIS_PASSWORD=sysreptorredispassword

# Task Queue (Celery via Redis)
CELERY_BROKER_URL=redis://:sysreptorredispassword@sysreptor-redis:6379/0
CELERY_RESULT_BACKEND=redis://:sysreptorredispassword@sysreptor-redis:6379/0

# MFA / FIDO2 WebAuthn
MFA_FIDO2_RP_ID=your-domain.example.com

# Features and Plugins
ENABLE_PRIVATE_DESIGNS=true
ENABLED_PLUGINS=cyberchef,graphqlvoyager,checkthehash
