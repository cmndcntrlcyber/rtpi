# RTPI SysReptor Caddy Configuration
# Reverse proxy for containerized SysReptor on port 7777
# External access: c3s-reports.attck.nexus -> NPM -> :7777 -> sysreptor-app:8000

:7777 {
    reverse_proxy sysreptor-app:8000 {
        # Pass websocket upgrade headers for real-time collaboration
        header_up X-Forwarded-Proto {http.request.header.X-Forwarded-Proto}
    }

    log {
        output file /var/log/caddy/access.log
        format json
    }

    handle_errors {
        respond "{http.error.status_code} {http.error.status_text}"
    }

    header {
        -Server
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
        X-XSS-Protection "1; mode=block"
        Referrer-Policy strict-origin-when-cross-origin
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
    }
}
