# RTPI OffSec Agent: C3 (Custom Command and Control)
# Windows-focused C2 framework for covert operations
#
# Categories: C2 Frameworks, Covert Channels, Post-Exploitation
# Primary Focus: C3 relay network and covert channel management
# Source: https://github.com/ReversecLabs/C3
#
# MITRE ATT&CK Tactics: Command and Control (TA0011), Defense Evasion (TA0005)

FROM rtpi/offsec-base:latest

# Set agent type for MCP server
ENV AGENT_TYPE=c3-c2
ENV TOOLS_PATH=/opt/tools
ENV C3_HOME=/opt/c3

# Switch to root for package installation
USER root

# Install C3 dependencies
RUN apt-get update && apt-get install -y \
    # Build tools (C3 is C++ based)
    build-essential cmake \
    # Windows cross-compilation
    mingw-w64 \
    # Network tools
    nmap netcat-openbsd socat \
    # SSL/crypto
    openssl libssl-dev \
    # Python for scripts
    python3-dev python3-pip \
    # Utilities
    unzip jq git \
    && rm -rf /var/lib/apt/lists/*

# Install .NET SDK 8.0 (C3 gateway uses .NET)
RUN apt-get update && \
    apt-get install -y wget && \
    . /etc/os-release && \
    wget -q "https://packages.microsoft.com/config/ubuntu/${VERSION_ID}/packages-microsoft-prod.deb" 2>/dev/null && \
    dpkg -i packages-microsoft-prod.deb 2>/dev/null && \
    rm -f packages-microsoft-prod.deb && \
    apt-get update && \
    (apt-get install -y dotnet-sdk-8.0 || echo "dotnet-sdk-8.0 not available for this architecture") && \
    rm -rf /var/lib/apt/lists/*

# Clone and build C3
RUN mkdir -p ${C3_HOME} && \
    git clone --depth 1 https://github.com/ReversecLabs/C3.git ${C3_HOME}/src || \
    echo "C3 clone deferred to activation"

# Install Python dependencies for C3 management
RUN pip3 install --no-cache-dir \
    requests \
    websockets \
    pycryptodome \
    2>/dev/null || true

# Create activation directory
RUN mkdir -p /opt/c2-setup

# Copy dormant entrypoint
COPY c3-entrypoint.sh /opt/c3-entrypoint.sh
RUN chmod +x /opt/c3-entrypoint.sh

# C3 Gateway web UI port + MCP server
EXPOSE 52935 9000

# Switch back to agent user
USER agent
WORKDIR /home/agent

ENTRYPOINT ["/opt/c3-entrypoint.sh"]
